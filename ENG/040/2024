          "text": [
            "536.0666666666667\n"
          ]
        }
      ],
      "source": [
        "# 1. Assign data to variables\n",
        "principal = 172000\n",
        "boe_rate = 2.25\n",
        "over_rate = 1.49\n",
        "\n",
        "# 2. Calculate the total annual interest rate (as a percentage)\n",
        "total_annual_rate_pct = boe_rate + over_rate\n",
        "\n",
        "# 3. Convert percentage to a decimal and calculate annual interest\n",
        "# (Rate / 100) * principal\n",
        "annual_interest = (total_annual_rate_pct / 100) * principal\n",
        "\n",
        "# 4. Divide by 12 to get the monthly interest payment\n",
        "interest = annual_interest / 12\n",
        "\n",
        "# Print the result\n",
        "print(interest)\n"
      ]
